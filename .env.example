# ============================================================
# 抖音创作顾问 Agent — 环境变量配置模板
# 复制此文件为 .env 并填入你的 API 密钥
# ============================================================

# DeepSeek API（用于 NLP 语义分析和内容生成）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Unsplash API（用于图片搜索，英文关键词）
# 获取地址：https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your-unsplash-key-here

# Pexels API（用于图片搜索，支持中文）
# 获取地址：https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-key-here

# 抖音开放平台（可选，用于获取官方热点/音乐数据）
# 获取地址：https://open.douyin.com/
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=

# HTTP 代理（可选，为空则直连）
# 格式：http://127.0.0.1:7897
PROXY_URL=

# Redis 短期记忆（可选，为空则禁用 Redis 缓存功能）
# 格式：redis://[:password@]host:port/db
# 设置密码：redis-cli CONFIG SET requirepass "your-password"
REDIS_URL=redis://127.0.0.1:6379/0

# Qdrant 公共向量数据库（可选，用于语义搜索）
QDRANT_URL=http://127.0.0.1:6333

# Embedding 模型配置
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DEVICE=cpu
HF_ENDPOINT=https://hf-mirror.com

# CORS 白名单（逗号分隔，用于前端访问后端 API）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# API 认证密钥（用于保护后端 API 端点）
# 生成方式：python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=your-api-key-here

# Playwright 无头模式（1/true/yes 启用无头，默认 false）
HEADLESS=false
